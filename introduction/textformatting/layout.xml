<Layout xmlns="urn:speedata.de/2021/xts/en" xmlns:sd="urn:speedata.de/2021/xtsfunctions/en" xmlns:h="http://www.w3.org/1999/xhtml">
    <SetGrid height="14pt" width="1cm" />

    <Stylesheet>
    @font-face {
        font-family: code;
        src: local("CamingoCode Regular");
        size-adjust: 80%;
    }
    .title {
        font-weight: bold;
        font-size: 16pt;
        line-height: 18pt;
    }
    code {
        font-family: code;
    }
    body {
        font-size: 14pt;
        font-family: serif;
    }
    </Stylesheet>

    <Record match="data">
        <PlaceObject>
            <Textblock width="8">
                <Paragraph>
                    <Value>There are various ways to put HTML like formatting in your PDF document. See the contents of the <code>layout.xml</code> and <code>data.xml</code>.</Value>
                </Paragraph>
            </Textblock>
        </PlaceObject>
        <NextRow rows="2" />
        <PlaceObject>
            <Textblock>
                <Paragraph class="title">
                    <Value>Text and markup from the CDATA section:</Value>
                </Paragraph>
                <HTML select="html" />
            </Textblock>
        </PlaceObject>
        <PlaceObject>
            <Textblock>
                <Paragraph class="title">
                    <Value>Text and markup from the data file:</Value>
                </Paragraph>
                <Paragraph>
                    <CopyOf select="text" />
                </Paragraph>
            </Textblock>
        </PlaceObject>
        <PlaceObject>
            <Textblock>
                <Paragraph class="title">
                    <Value>Text and markup from the layout file:</Value>
                </Paragraph>
                <Paragraph>
                    <Value>A </Value>
                    <I>
                        <Value>wonderful</Value>
                    </I>
                    <Value> serenity has </Value>
                    <B>
                        <Value>taken possession</Value>
                    </B>
                    <Value> of my entire soul,</Value>
                    <Ul>
                        <Li>
                            <Value>like these</Value>
                        </Li>
                        <Li>
                            <Value>sweet mornings</Value>
                        </Li>
                        <Li>
                            <Value>of spring</Value>
                        </Li>
                        <Li>
                            <Value>which I enjoy</Value>
                        </Li>
                    </Ul>
                </Paragraph>
                <Paragraph>
                    <Value>&amp; # \ { } %</Value>
                </Paragraph>
            </Textblock>
        </PlaceObject>
        <PlaceObject>
            <Textblock>
                <Paragraph class="title">
                    <Value>Text and markup as HTML in the layout file:</Value>
                </Paragraph>
                <HTML>
                    A
                    <h:i>
                        wonderful
                    </h:i>
                    serenity has
                    <h:b>
                        taken possession
                    </h:b>
                    of my entire soul,
                    <h:ul>
                        <h:li>
                            like these
                        </h:li>
                        <h:li>
                            sweet mornings
                        </h:li>
                        <h:li>
                            of spring
                        </h:li>
                        <h:li>
                            which I enjoy
                        </h:li>
                    </h:ul>
                    &amp; # \ { } %
                </HTML>
            </Textblock>
        </PlaceObject>
    </Record>
</Layout>
