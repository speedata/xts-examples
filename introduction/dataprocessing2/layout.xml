<Layout xmlns="urn:speedata.de/2021/xts/en" xmlns:sd="urn:speedata.de/2021/xtsfunctions/en">
  <SetGrid nx="20" height="12pt" />


  <!-- This example uses "ForAll" to visit each child node -->
  <Record match="root">
    <ForAll select="child">
      <PlaceObject>
        <HTML expand-text="yes">
          <div style="width: 5cm">
            <barcode type="code128" value="{.}" width="{sd:grid-width(5,'cm')}cm" height="1.5cm" />
            <br />
            <p style="text-align: center; font-size: 10pt; margin-top: 2pt">
              {.}
            </p>
          </div>
        </HTML>
      </PlaceObject>
      <NextRow rows="2" />
    </ForAll>
  </Record>
</Layout>
